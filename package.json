{
  "name": "qk-chinese-to-gt-converter",
  "displayName": "qk-chinese-to-gt-converter",
  "description": "将代码中的中文转换为 gt('') 函数包裹的形式",
  "version": "1.0.5",
  "publisher": "liurun",
  "icon": "resources/thunder.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "activationEvents": [
    "onCommand:chineseToGt.convertFile",
    "onCommand:chineseToGt.convertSelection",
    "onCommand:chineseToGt.convertFolder"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chineseToGt.convertFile",
        "title": "转化中文为 => gt('中文')",
        "category": "Chinese to gt()"
      },
      {
        "command": "chineseToGt.convertSelection",
        "title": "转化选中部分的中文为 => gt('中文')",
        "category": "Chinese to gt()"
      },
      {
        "command": "chineseToGt.convertFolder",
        "title": "转化文件夹中的所有中文为 gt('中文')",
        "category": "Chinese to gt()"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "chineseToGt.convertSelection",
          "when": "editorHasSelection",
          "group": "1_modification"
        },
        {
          "command": "chineseToGt.convertFile",
          "group": "1_modification"
        }
      ],
      "editor/title": [
        {
          "command": "chineseToGt.convertFile",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "chineseToGt.convertFolder",
          "when": "explorerResourceIsFolder",
          "group": "1_modification"
        },
        {
          "command": "chineseToGt.convertFolder",
          "when": "explorerResourceIsFile",
          "group": "1_modification"
        }
      ]
    },
    "keybindings": [
      {
        "command": "chineseToGt.convertSelection",
        "key": "ctrl+shift+g",
        "mac": "cmd+shift+g",
        "when": "editorHasSelection"
      },
      {
        "command": "chineseToGt.convertFile",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g"
      }
    ],
    "configuration": {
      "title": "Chinese To Gt Translation",
      "properties": {
        "chineseToGt.translation.provider": {
          "type": "string",
          "enum": ["auto", "none", "alibaba"],
          "default": "auto",
          "description": "复杂中文转英文时使用的内置翻译提供方。auto 会优先读取本插件配置，其次复用 samge.translate 的 alibaba 配置。"
        },
        "chineseToGt.translation.alibaba.accessKeyId": {
          "type": "string",
          "default": "",
          "description": "内置阿里翻译的 AccessKeyId。"
        },
        "chineseToGt.translation.alibaba.accessKeySecret": {
          "type": "string",
          "default": "",
          "description": "内置阿里翻译的 AccessKeySecret。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node out/converter.test.js && node out/i18n-helper.test.js && node out/translator.test.js"
  },
  "dependencies": {
    "typescript": "^4.9.0"
  },
  "devDependencies": {
    "@types/node": "^16.x",
    "@types/vscode": "^1.60.0"
  }
}
